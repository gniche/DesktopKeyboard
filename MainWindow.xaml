<Window x:Class="DesktopKeyboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DesktopKeyboard" Height="360" Width="850"
        Topmost="True" Focusable="False" ShowActivated="False"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Visibility="Hidden" ShowInTaskbar="False">
    <Window.Resources>
        <SolidColorBrush x:Key="KeyBg" Color="#252525"/>
        <Style TargetType="Button" x:Key="KeyStyle">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="{DynamicResource KeyBg}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,3">
                                <!-- Black halo keeps white glyphs readable even when keys are translucent -->
                                <ContentPresenter.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="0" Opacity="1" RenderingBias="Quality"/>
                                </ContentPresenter.Effect>
                            </ContentPresenter>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#353535"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#111111"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button" x:Key="TopIconStyle" BasedOn="{StaticResource KeyStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="5,0"/>
        </Style>

        <!-- Transparent repeat buttons so the slider track shows through -->
        <Style x:Key="TransparentRepeat" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Large, touch-friendly slider: big thumb, tall track, tap-to-set -->
        <Style x:Key="TouchSlider" TargetType="Slider">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Height" Value="56"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Border Height="14" CornerRadius="7" Background="#444" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource TransparentRepeat}" Command="Slider.DecreaseLarge"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource TransparentRepeat}" Command="Slider.IncreaseLarge"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="44" Height="44" Fill="#4A90E2" Stroke="White" StrokeThickness="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Viewbox Stretch="Uniform">
        <Border x:Name="MainBorder" Width="850" Height="360" Background="#111111" CornerRadius="8" BorderBrush="#333" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="45"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top bar -->
                <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                    <Button Content="Esc" Tag="ESC" Style="{StaticResource KeyStyle}"
                            HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,3,0,0"
                            Width="60" Height="38" FontSize="16" Click="Key_Click"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,10,0">
                        <Button x:Name="BtnTheme" Content="🎨 Theme" Style="{StaticResource TopIconStyle}" Width="95" Click="ThemeButton_Click"/>
                        <Button x:Name="BtnLayout" Content="⌨ Base" Style="{StaticResource TopIconStyle}" Width="80" Click="LayoutButton_Click"/>
                        <Button Content="✕" Style="{StaticResource TopIconStyle}" Width="40" FontSize="20" Click="CloseButton_Click"/>
                    </StackPanel>

                    <Popup x:Name="ThemePopup" PlacementTarget="{Binding ElementName=BtnTheme}" Placement="Bottom"
                           StaysOpen="False" AllowsTransparency="True">
                        <Border Background="#1E1E1E" CornerRadius="6" Padding="16" BorderBrush="#333" BorderThickness="1">
                            <StackPanel Width="340">
                                <TextBlock Text="Colour" Foreground="White" FontSize="16" Margin="0,0,0,4"/>
                                <Slider x:Name="HueSlider" Style="{StaticResource TouchSlider}" Minimum="0" Maximum="360" Value="0"
                                        ValueChanged="HueSlider_ValueChanged"/>
                                <TextBlock x:Name="BrightnessLabel" Text="Brightness: 100%" Foreground="White" FontSize="16" Margin="0,10,0,4"/>
                                <Slider x:Name="BrightnessSlider" Style="{StaticResource TouchSlider}" Minimum="50" Maximum="300" Value="100"
                                        ValueChanged="BrightnessSlider_ValueChanged"/>
                                <TextBlock x:Name="OpacityLabel" Text="Background opacity: 100%" Foreground="White" FontSize="16" Margin="0,10,0,4"/>
                                <Slider x:Name="OpacitySlider" Style="{StaticResource TouchSlider}" Minimum="10" Maximum="100" Value="100"
                                        ValueChanged="OpacitySlider_ValueChanged"/>
                                <TextBlock x:Name="SizeLabel" Text="Size: Medium" Foreground="White" FontSize="16" Margin="0,10,0,4"/>
                                <Slider x:Name="SizeSlider" Style="{StaticResource TouchSlider}" Minimum="0" Maximum="2" Value="1"
                                        IsSnapToTickEnabled="True" TickFrequency="1" SmallChange="1" LargeChange="1"
                                        ValueChanged="SizeSlider_ValueChanged"/>
                                <Button Content="Reset to grey" Style="{StaticResource KeyStyle}" Background="#252525"
                                        Height="44" FontSize="16" Margin="0,12,0,0" Click="HueReset_Click"/>
                                <Button x:Name="BtnStartup" Content="Run on startup: Off" Style="{StaticResource KeyStyle}" Background="#252525"
                                        Height="44" FontSize="16" Margin="0,8,0,0" Click="StartupButton_Click"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>

                <!-- ═══════════════════════════════════════════════════════ -->
                <!-- Layout 1: Base (current keys + Win + Alt)              -->
                <!-- ═══════════════════════════════════════════════════════ -->
                <Grid x:Name="Layout1Panel" Grid.Row="1" Margin="10,5,10,15" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <UniformGrid Grid.Row="0" Rows="1" Columns="11">
                        <Button Style="{StaticResource KeyStyle}" Content="1" Tag="1" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="2" Tag="2" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="3" Tag="3" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="4" Tag="4" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="5" Tag="5" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="6" Tag="6" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="7" Tag="7" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="8" Tag="8" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="9" Tag="9" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="0" Tag="0" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="Del" Tag="BACK" Click="Key_Click" FontSize="18"/>
                    </UniformGrid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="1.2*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"  Style="{StaticResource KeyStyle}" Content="q" Tag="Q" Click="Key_Click"/>
                        <Button Grid.Column="1"  Style="{StaticResource KeyStyle}" Content="w" Tag="W" Click="Key_Click"/>
                        <Button Grid.Column="2"  Style="{StaticResource KeyStyle}" Content="e" Tag="E" Click="Key_Click"/>
                        <Button Grid.Column="3"  Style="{StaticResource KeyStyle}" Content="r" Tag="R" Click="Key_Click"/>
                        <Button Grid.Column="4"  Style="{StaticResource KeyStyle}" Content="t" Tag="T" Click="Key_Click"/>
                        <Button Grid.Column="5"  Style="{StaticResource KeyStyle}" Content="y" Tag="Y" Click="Key_Click"/>
                        <Button Grid.Column="6"  Style="{StaticResource KeyStyle}" Content="u" Tag="U" Click="Key_Click"/>
                        <Button Grid.Column="7"  Style="{StaticResource KeyStyle}" Content="i" Tag="I" Click="Key_Click"/>
                        <Button Grid.Column="8"  Style="{StaticResource KeyStyle}" Content="o" Tag="O" Click="Key_Click"/>
                        <Button Grid.Column="9"  Style="{StaticResource KeyStyle}" Content="p" Tag="P" Click="Key_Click"/>
                        <Button Grid.Column="10" Style="{StaticResource KeyStyle}" Content="⌫" Tag="BACK" Click="Key_Click"/>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.5*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="1.5*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="1"  Style="{StaticResource KeyStyle}" Content="a" Tag="A" Click="Key_Click"/>
                        <Button Grid.Column="2"  Style="{StaticResource KeyStyle}" Content="s" Tag="S" Click="Key_Click"/>
                        <Button Grid.Column="3"  Style="{StaticResource KeyStyle}" Content="d" Tag="D" Click="Key_Click"/>
                        <Button Grid.Column="4"  Style="{StaticResource KeyStyle}" Content="f" Tag="F" Click="Key_Click"/>
                        <Button Grid.Column="5"  Style="{StaticResource KeyStyle}" Content="g" Tag="G" Click="Key_Click"/>
                        <Button Grid.Column="6"  Style="{StaticResource KeyStyle}" Content="h" Tag="H" Click="Key_Click"/>
                        <Button Grid.Column="7"  Style="{StaticResource KeyStyle}" Content="j" Tag="J" Click="Key_Click"/>
                        <Button Grid.Column="8"  Style="{StaticResource KeyStyle}" Content="k" Tag="K" Click="Key_Click"/>
                        <Button Grid.Column="9"  Style="{StaticResource KeyStyle}" Content="l" Tag="L" Click="Key_Click"/>
                        <Button Grid.Column="10" Style="{StaticResource KeyStyle}" Content="↵" Tag="ENTER" Click="Key_Click"/>
                    </Grid>

                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"  Style="{StaticResource KeyStyle}" Content="⇧" Tag="TOGGLE_SHIFT" Click="Key_Click" FontSize="26"/>
                        <Button Grid.Column="1"  Style="{StaticResource KeyStyle}" Content="z" Tag="Z" Click="Key_Click"/>
                        <Button Grid.Column="2"  Style="{StaticResource KeyStyle}" Content="x" Tag="X" Click="Key_Click"/>
                        <Button Grid.Column="3"  Style="{StaticResource KeyStyle}" Content="c" Tag="C" Click="Key_Click"/>
                        <Button Grid.Column="4"  Style="{StaticResource KeyStyle}" Content="v" Tag="V" Click="Key_Click"/>
                        <Button Grid.Column="5"  Style="{StaticResource KeyStyle}" Content="b" Tag="B" Click="Key_Click"/>
                        <Button Grid.Column="6"  Style="{StaticResource KeyStyle}" Content="n" Tag="N" Click="Key_Click"/>
                        <Button Grid.Column="7"  Style="{StaticResource KeyStyle}" Content="m" Tag="M" Click="Key_Click"/>
                        <Button Grid.Column="8"  Style="{StaticResource KeyStyle}" Content="," Tag="COMMA" Click="Key_Click"/>
                        <Button Grid.Column="9"  Style="{StaticResource KeyStyle}" Content="." Tag="PERIOD" Click="Key_Click"/>
                        <Button Grid.Column="10" Style="{StaticResource KeyStyle}" Content="/" Tag="SLASH" Click="Key_Click"/>
                        <Button Grid.Column="11" Style="{StaticResource KeyStyle}" Content="↑" Tag="UP" Click="Key_Click" FontSize="26"/>
                    </Grid>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/><ColumnDefinition Width="1.5*"/><ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="6*"/>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource KeyStyle}" Content="Ctrl" Tag="TOGGLE_CTRL" Click="Key_Click" FontSize="18"/>
                        <Button Grid.Column="1" Style="{StaticResource KeyStyle}" Content="⊞" Tag="WIN" Click="Key_Click" FontSize="20"/>
                        <Button Grid.Column="2" Style="{StaticResource KeyStyle}" Content="Alt" Tag="TOGGLE_ALT" Click="Key_Click" FontSize="18"/>
                        <Button Grid.Column="3" Style="{StaticResource KeyStyle}" Content="Space" Tag="SPACE" Click="Key_Click" FontSize="18"/>
                        <Button Grid.Column="4" Style="{StaticResource KeyStyle}" Content="←" Tag="LEFT" Click="Key_Click" FontSize="22"/>
                        <Button Grid.Column="5" Style="{StaticResource KeyStyle}" Content="↓" Tag="DOWN" Click="Key_Click" FontSize="22"/>
                        <Button Grid.Column="6" Style="{StaticResource KeyStyle}" Content="→" Tag="RIGHT" Click="Key_Click" FontSize="22"/>
                    </Grid>
                </Grid>

                <!-- ═══════════════════════════════════════════════════════ -->
                <!-- Layout 2: Nav (Base + Home/End/PgUp/PgDn)             -->
                <!-- ═══════════════════════════════════════════════════════ -->
                <Grid x:Name="Layout2Panel" Grid.Row="1" Margin="10,5,10,15" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <UniformGrid Grid.Row="0" Rows="1" Columns="11">
                        <Button Style="{StaticResource KeyStyle}" Content="1" Tag="1" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="2" Tag="2" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="3" Tag="3" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="4" Tag="4" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="5" Tag="5" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="6" Tag="6" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="7" Tag="7" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="8" Tag="8" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="9" Tag="9" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="0" Tag="0" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="Del" Tag="BACK" Click="Key_Click" FontSize="18"/>
                    </UniformGrid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="1.2*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"  Style="{StaticResource KeyStyle}" Content="q" Tag="Q" Click="Key_Click"/>
                        <Button Grid.Column="1"  Style="{StaticResource KeyStyle}" Content="w" Tag="W" Click="Key_Click"/>
                        <Button Grid.Column="2"  Style="{StaticResource KeyStyle}" Content="e" Tag="E" Click="Key_Click"/>
                        <Button Grid.Column="3"  Style="{StaticResource KeyStyle}" Content="r" Tag="R" Click="Key_Click"/>
                        <Button Grid.Column="4"  Style="{StaticResource KeyStyle}" Content="t" Tag="T" Click="Key_Click"/>
                        <Button Grid.Column="5"  Style="{StaticResource KeyStyle}" Content="y" Tag="Y" Click="Key_Click"/>
                        <Button Grid.Column="6"  Style="{StaticResource KeyStyle}" Content="u" Tag="U" Click="Key_Click"/>
                        <Button Grid.Column="7"  Style="{StaticResource KeyStyle}" Content="i" Tag="I" Click="Key_Click"/>
                        <Button Grid.Column="8"  Style="{StaticResource KeyStyle}" Content="o" Tag="O" Click="Key_Click"/>
                        <Button Grid.Column="9"  Style="{StaticResource KeyStyle}" Content="p" Tag="P" Click="Key_Click"/>
                        <Button Grid.Column="10" Style="{StaticResource KeyStyle}" Content="⌫" Tag="BACK" Click="Key_Click"/>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.5*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="1.5*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="1"  Style="{StaticResource KeyStyle}" Content="a" Tag="A" Click="Key_Click"/>
                        <Button Grid.Column="2"  Style="{StaticResource KeyStyle}" Content="s" Tag="S" Click="Key_Click"/>
                        <Button Grid.Column="3"  Style="{StaticResource KeyStyle}" Content="d" Tag="D" Click="Key_Click"/>
                        <Button Grid.Column="4"  Style="{StaticResource KeyStyle}" Content="f" Tag="F" Click="Key_Click"/>
                        <Button Grid.Column="5"  Style="{StaticResource KeyStyle}" Content="g" Tag="G" Click="Key_Click"/>
                        <Button Grid.Column="6"  Style="{StaticResource KeyStyle}" Content="h" Tag="H" Click="Key_Click"/>
                        <Button Grid.Column="7"  Style="{StaticResource KeyStyle}" Content="j" Tag="J" Click="Key_Click"/>
                        <Button Grid.Column="8"  Style="{StaticResource KeyStyle}" Content="k" Tag="K" Click="Key_Click"/>
                        <Button Grid.Column="9"  Style="{StaticResource KeyStyle}" Content="l" Tag="L" Click="Key_Click"/>
                        <Button Grid.Column="10" Style="{StaticResource KeyStyle}" Content="↵" Tag="ENTER" Click="Key_Click"/>
                    </Grid>

                    <!-- Shift row + PgUp/PgDn on far right -->
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"  Style="{StaticResource KeyStyle}" Content="⇧" Tag="TOGGLE_SHIFT" Click="Key_Click" FontSize="26"/>
                        <Button Grid.Column="1"  Style="{StaticResource KeyStyle}" Content="z" Tag="Z" Click="Key_Click"/>
                        <Button Grid.Column="2"  Style="{StaticResource KeyStyle}" Content="x" Tag="X" Click="Key_Click"/>
                        <Button Grid.Column="3"  Style="{StaticResource KeyStyle}" Content="c" Tag="C" Click="Key_Click"/>
                        <Button Grid.Column="4"  Style="{StaticResource KeyStyle}" Content="v" Tag="V" Click="Key_Click"/>
                        <Button Grid.Column="5"  Style="{StaticResource KeyStyle}" Content="b" Tag="B" Click="Key_Click"/>
                        <Button Grid.Column="6"  Style="{StaticResource KeyStyle}" Content="n" Tag="N" Click="Key_Click"/>
                        <Button Grid.Column="7"  Style="{StaticResource KeyStyle}" Content="m" Tag="M" Click="Key_Click"/>
                        <Button Grid.Column="8"  Style="{StaticResource KeyStyle}" Content="," Tag="COMMA" Click="Key_Click"/>
                        <Button Grid.Column="9"  Style="{StaticResource KeyStyle}" Content="." Tag="PERIOD" Click="Key_Click"/>
                        <Button Grid.Column="10" Style="{StaticResource KeyStyle}" Content="/" Tag="SLASH" Click="Key_Click"/>
                        <Button Grid.Column="11" Style="{StaticResource KeyStyle}" Content="↑" Tag="UP" Click="Key_Click" FontSize="26"/>
                        <Button Grid.Column="12" Style="{StaticResource KeyStyle}" Content="PgUp" Tag="PGUP" Click="Key_Click" FontSize="15"/>
                        <Button Grid.Column="13" Style="{StaticResource KeyStyle}" Content="PgDn" Tag="PGDN" Click="Key_Click" FontSize="15"/>
                    </Grid>

                    <!-- Bottom row + Home/End on far right -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/><ColumnDefinition Width="1.5*"/><ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="5*"/>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource KeyStyle}" Content="Ctrl" Tag="TOGGLE_CTRL" Click="Key_Click" FontSize="18"/>
                        <Button Grid.Column="1" Style="{StaticResource KeyStyle}" Content="⊞" Tag="WIN" Click="Key_Click" FontSize="20"/>
                        <Button Grid.Column="2" Style="{StaticResource KeyStyle}" Content="Alt" Tag="TOGGLE_ALT" Click="Key_Click" FontSize="18"/>
                        <Button Grid.Column="3" Style="{StaticResource KeyStyle}" Content="Space" Tag="SPACE" Click="Key_Click" FontSize="18"/>
                        <Button Grid.Column="4" Style="{StaticResource KeyStyle}" Content="←" Tag="LEFT" Click="Key_Click" FontSize="22"/>
                        <Button Grid.Column="5" Style="{StaticResource KeyStyle}" Content="↓" Tag="DOWN" Click="Key_Click" FontSize="22"/>
                        <Button Grid.Column="6" Style="{StaticResource KeyStyle}" Content="→" Tag="RIGHT" Click="Key_Click" FontSize="22"/>
                        <Button Grid.Column="7" Style="{StaticResource KeyStyle}" Content="Home" Tag="HOME" Click="Key_Click" FontSize="15"/>
                        <Button Grid.Column="8" Style="{StaticResource KeyStyle}" Content="End" Tag="END" Click="Key_Click" FontSize="15"/>
                    </Grid>
                </Grid>

                <!-- ═══════════════════════════════════════════════════════ -->
                <!-- Layout 3: Fn+Nav (Nav + F1-F12 row)                   -->
                <!-- ═══════════════════════════════════════════════════════ -->
                <Grid x:Name="Layout3Panel" Grid.Row="1" Margin="10,5,10,15" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- F-key row -->
                    <UniformGrid Grid.Row="0" Rows="1" Columns="12">
                        <Button Style="{StaticResource KeyStyle}" Content="F1"  Tag="F1"  Click="Key_Click" FontSize="16"/>
                        <Button Style="{StaticResource KeyStyle}" Content="F2"  Tag="F2"  Click="Key_Click" FontSize="16"/>
                        <Button Style="{StaticResource KeyStyle}" Content="F3"  Tag="F3"  Click="Key_Click" FontSize="16"/>
                        <Button Style="{StaticResource KeyStyle}" Content="F4"  Tag="F4"  Click="Key_Click" FontSize="16"/>
                        <Button Style="{StaticResource KeyStyle}" Content="F5"  Tag="F5"  Click="Key_Click" FontSize="16"/>
                        <Button Style="{StaticResource KeyStyle}" Content="F6"  Tag="F6"  Click="Key_Click" FontSize="16"/>
                        <Button Style="{StaticResource KeyStyle}" Content="F7"  Tag="F7"  Click="Key_Click" FontSize="16"/>
                        <Button Style="{StaticResource KeyStyle}" Content="F8"  Tag="F8"  Click="Key_Click" FontSize="16"/>
                        <Button Style="{StaticResource KeyStyle}" Content="F9"  Tag="F9"  Click="Key_Click" FontSize="16"/>
                        <Button Style="{StaticResource KeyStyle}" Content="F10" Tag="F10" Click="Key_Click" FontSize="16"/>
                        <Button Style="{StaticResource KeyStyle}" Content="F11" Tag="F11" Click="Key_Click" FontSize="16"/>
                        <Button Style="{StaticResource KeyStyle}" Content="F12" Tag="F12" Click="Key_Click" FontSize="16"/>
                    </UniformGrid>

                    <UniformGrid Grid.Row="1" Rows="1" Columns="11">
                        <Button Style="{StaticResource KeyStyle}" Content="1" Tag="1" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="2" Tag="2" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="3" Tag="3" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="4" Tag="4" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="5" Tag="5" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="6" Tag="6" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="7" Tag="7" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="8" Tag="8" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="9" Tag="9" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="0" Tag="0" Click="Key_Click"/>
                        <Button Style="{StaticResource KeyStyle}" Content="Del" Tag="BACK" Click="Key_Click" FontSize="18"/>
                    </UniformGrid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
