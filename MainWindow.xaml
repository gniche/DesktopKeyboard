<Window x:Class="DesktopKeyboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DesktopKeyboard" Height="360" Width="850"
        Topmost="True" Focusable="False" ShowActivated="False"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Visibility="Hidden" ShowInTaskbar="False">
    <Window.Resources>
        <SolidColorBrush x:Key="KeyBg" Color="#252525"/>
        <Style TargetType="Button" x:Key="KeyStyle">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="{DynamicResource KeyBg}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="6"/>
                            <!-- Press highlight overlay: snaps on when pressed, fades out over 0.2s on
                                 release. A per-button overlay (not the shared Background brush) avoids
                                 the touch "stuck highlight" since it doesn't depend on IsMouseOver. -->
                            <Border x:Name="PressHighlight" Background="#40FFFFFF" CornerRadius="6" Opacity="0"/>
                            <!-- Black outline keeps white glyphs readable even when keys are translucent.
                                 Four 1px-offset black copies of the glyph form the outline. This is pure
                                 text drawing with NO pixel-shader Effect: a BlurEffect/DropShadowEffect
                                 here forces an offscreen render pass per key, re-rasterized under the
                                 Viewbox scale on every press-animation frame — the cause of high CPU. -->
                            <Grid Margin="0,0,0,3" TextElement.Foreground="Black">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                    <ContentPresenter.RenderTransform><TranslateTransform X="-1" Y="-1"/></ContentPresenter.RenderTransform>
                                </ContentPresenter>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                    <ContentPresenter.RenderTransform><TranslateTransform X="1" Y="-1"/></ContentPresenter.RenderTransform>
                                </ContentPresenter>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                    <ContentPresenter.RenderTransform><TranslateTransform X="-1" Y="1"/></ContentPresenter.RenderTransform>
                                </ContentPresenter>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                    <ContentPresenter.RenderTransform><TranslateTransform X="1" Y="1"/></ContentPresenter.RenderTransform>
                                </ContentPresenter>
                            </Grid>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,3"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PressHighlight" Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0:0:0"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PressHighlight" Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="TopIconStyle" BasedOn="{StaticResource KeyStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="5,0"/>
        </Style>

        <!-- Transparent repeat buttons so the slider track shows through -->
        <Style x:Key="TransparentRepeat" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Large, touch-friendly slider: big thumb, tall track, tap-to-set -->
        <Style x:Key="TouchSlider" TargetType="Slider">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Height" Value="56"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Border Height="14" CornerRadius="7" Background="#444" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource TransparentRepeat}" Command="Slider.DecreaseLarge"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource TransparentRepeat}" Command="Slider.IncreaseLarge"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="44" Height="44" Fill="#4A90E2" Stroke="White" StrokeThickness="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Viewbox Stretch="Uniform">
        <Border x:Name="MainBorder" Width="850" Height="360" Background="#111111" CornerRadius="8" BorderBrush="#333" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="45"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top bar -->
                <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                    <Button Content="Esc" Tag="ESC" Style="{StaticResource KeyStyle}"
                            HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,3,0,0"
                            Width="60" Height="38" FontSize="16" Click="Key_Click"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,10,0">
                        <Button x:Name="BtnTheme" Content="🎨" Style="{StaticResource TopIconStyle}" Width="44" Click="ThemeButton_Click"/>
                        <Button x:Name="BtnLayout" Content="⌨" Style="{StaticResource TopIconStyle}" Width="44" Click="LayoutButton_Click"/>
                        <Button Content="✕" Style="{StaticResource TopIconStyle}" Width="40" FontSize="20" Click="CloseButton_Click"/>
                    </StackPanel>

                    <Popup x:Name="ThemePopup" PlacementTarget="{Binding ElementName=BtnTheme}" Placement="Bottom"
                           StaysOpen="False" AllowsTransparency="True">
                        <Border Background="#1E1E1E" CornerRadius="6" Padding="16" BorderBrush="#333" BorderThickness="1">
                            <StackPanel Width="340">
                                <TextBlock Text="Colour" Foreground="White" FontSize="16" Margin="0,0,0,4"/>
                                <Slider x:Name="HueSlider" Style="{StaticResource TouchSlider}" Minimum="0" Maximum="360" Value="0"
                                        ValueChanged="HueSlider_ValueChanged"/>
                                <TextBlock x:Name="BrightnessLabel" Text="Brightness: 100%" Foreground="White" FontSize="16" Margin="0,10,0,4"/>
                                <Slider x:Name="BrightnessSlider" Style="{StaticResource TouchSlider}" Minimum="50" Maximum="300" Value="100"
                                        ValueChanged="BrightnessSlider_ValueChanged"/>
                                <TextBlock x:Name="OpacityLabel" Text="Background opacity: 100%" Foreground="White" FontSize="16" Margin="0,10,0,4"/>
                                <Slider x:Name="OpacitySlider" Style="{StaticResource TouchSlider}" Minimum="10" Maximum="100" Value="100"
                                        ValueChanged="OpacitySlider_ValueChanged"/>
                                <TextBlock x:Name="SizeLabel" Text="Size: Medium" Foreground="White" FontSize="16" Margin="0,10,0,4"/>
                                <Slider x:Name="SizeSlider" Style="{StaticResource TouchSlider}" Minimum="0" Maximum="2" Value="1"
                                        IsSnapToTickEnabled="True" TickFrequency="1" SmallChange="1" LargeChange="1"
                                        ValueChanged="SizeSlider_ValueChanged"/>
                                <Button Content="Reset to grey" Style="{StaticResource KeyStyle}" Background="#252525"
                                        Height="44" FontSize="16" Margin="0,12,0,0" Click="HueReset_Click"/>
                                <Button x:Name="BtnStartup" Content="Run on startup: Off" Style="{StaticResource KeyStyle}" Background="#252525"
                                        Height="44" FontSize="16" Margin="0,8,0,0" Click="StartupButton_Click"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>

                <!-- ═══════════════════════════════════════════════════════ -->
                <!-- Keyboard — one definition. The layout button toggles the  -->
                <!-- F-key row, the Nav keys (PgUp/PgDn, Home/End) and numpad.  -->
                <!-- ═══════════════════════════════════════════════════════ -->
                <Grid Grid.Row="1" Margin="10,5,10,15">
                    <!-- Every key in this subtree gets KeyStyle implicitly, so the keys below
                         don't repeat Style="{StaticResource KeyStyle}". Top-bar/popup buttons
                         live outside this Grid and keep their own explicit styles. -->
                    <Grid.Resources>
                        <Style TargetType="Button" BasedOn="{StaticResource KeyStyle}"/>
                    </Grid.Resources>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition x:Name="NumpadCol" Width="0"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Number row -->
                        <UniformGrid Grid.Row="0" Rows="1" Columns="14">
                            <Button Content="`" Tag="GRAVE" Click="Key_Click"/>
                            <Button Content="1" Tag="1" Click="Key_Click"/>
                            <Button Content="2" Tag="2" Click="Key_Click"/>
                            <Button Content="3" Tag="3" Click="Key_Click"/>
                            <Button Content="4" Tag="4" Click="Key_Click"/>
                            <Button Content="5" Tag="5" Click="Key_Click"/>
                            <Button Content="6" Tag="6" Click="Key_Click"/>
                            <Button Content="7" Tag="7" Click="Key_Click"/>
                            <Button Content="8" Tag="8" Click="Key_Click"/>
                            <Button Content="9" Tag="9" Click="Key_Click"/>
                            <Button Content="0" Tag="0" Click="Key_Click"/>
                            <Button Content="-" Tag="MINUS" Click="Key_Click"/>
                            <Button Content="=" Tag="EQUALS" Click="Key_Click"/>
                            <Button Content="⌫" Tag="BACK" Click="Key_Click" FontSize="18"/>
                        </UniformGrid>

                        <!-- Top letter row (Tab + qwerty + \) -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.3*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="1.2*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"  Content="⇥" Tag="TAB" Click="Key_Click" FontSize="22"/>
                            <Button Grid.Column="1"  Content="q" Tag="Q" Click="Key_Click"/>
                            <Button Grid.Column="2"  Content="w" Tag="W" Click="Key_Click"/>
                            <Button Grid.Column="3"  Content="e" Tag="E" Click="Key_Click"/>
                            <Button Grid.Column="4"  Content="r" Tag="R" Click="Key_Click"/>
                            <Button Grid.Column="5"  Content="t" Tag="T" Click="Key_Click"/>
                            <Button Grid.Column="6"  Content="y" Tag="Y" Click="Key_Click"/>
                            <Button Grid.Column="7"  Content="u" Tag="U" Click="Key_Click"/>
                            <Button Grid.Column="8"  Content="i" Tag="I" Click="Key_Click"/>
                            <Button Grid.Column="9"  Content="o" Tag="O" Click="Key_Click"/>
                            <Button Grid.Column="10" Content="p" Tag="P" Click="Key_Click"/>
                            <Button Grid.Column="11" Content="\" Tag="BACKSLASH" Click="Key_Click"/>
                        </Grid>

                        <!-- Home row (Fn + asdf + Enter) -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.3*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="1.5*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"  Content="Fn" Tag="TOGGLE_FN" Click="Key_Click" FontSize="18"/>
                            <Button Grid.Column="1"  Content="a" Tag="A" Click="Key_Click"/>
                            <Button Grid.Column="2"  Content="s" Tag="S" Click="Key_Click"/>
                            <Button Grid.Column="3"  Content="d" Tag="D" Click="Key_Click"/>
                            <Button Grid.Column="4"  Content="f" Tag="F" Click="Key_Click"/>
                            <Button Grid.Column="5"  Content="g" Tag="G" Click="Key_Click"/>
                            <Button Grid.Column="6"  Content="h" Tag="H" Click="Key_Click"/>
                            <Button Grid.Column="7"  Content="j" Tag="J" Click="Key_Click"/>
                            <Button Grid.Column="8"  Content="k" Tag="K" Click="Key_Click"/>
                            <Button Grid.Column="9"  Content="l" Tag="L" Click="Key_Click"/>
                            <Button Grid.Column="10" Content="↵" Tag="ENTER" Click="Key_Click"/>
                        </Grid>

                        <!-- Shift row (incl. PgUp/PgDn) -->
                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.5*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"  Content="⇧" Tag="TOGGLE_SHIFT" Click="Key_Click" FontSize="26"/>
                            <Button Grid.Column="1"  Content="z" Tag="Z" Click="Key_Click"/>
                            <Button Grid.Column="2"  Content="x" Tag="X" Click="Key_Click"/>
                            <Button Grid.Column="3"  Content="c" Tag="C" Click="Key_Click"/>
                            <Button Grid.Column="4"  Content="v" Tag="V" Click="Key_Click"/>
                            <Button Grid.Column="5"  Content="b" Tag="B" Click="Key_Click"/>
                            <Button Grid.Column="6"  Content="n" Tag="N" Click="Key_Click"/>
                            <Button Grid.Column="7"  Content="m" Tag="M" Click="Key_Click"/>
                            <Button Grid.Column="8"  Content="," Tag="COMMA" Click="Key_Click"/>
                            <Button Grid.Column="9"  Content="." Tag="PERIOD" Click="Key_Click"/>
                            <Button Grid.Column="10" Content="/" Tag="SLASH" Click="Key_Click"/>
                            <Button Grid.Column="11" Content="↑" Tag="UP" Click="Key_Click" FontSize="26"/>
                            <Button Grid.Column="12" Content="PgUp" Tag="PGUP" Click="Key_Click" FontSize="15"/>
                            <Button Grid.Column="13" Content="PgDn" Tag="PGDN" Click="Key_Click" FontSize="15"/>
                        </Grid>

                        <!-- Bottom row (incl. Home/End) -->
                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.5*"/><ColumnDefinition Width="1.5*"/><ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="5*"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Ctrl" Tag="TOGGLE_CTRL" Click="Key_Click" FontSize="18"/>
                            <Button Grid.Column="1" Content="⊞" Tag="TOGGLE_WIN" Click="Key_Click" FontSize="20"/>
                            <Button Grid.Column="2" Content="Alt" Tag="TOGGLE_ALT" Click="Key_Click" FontSize="18"/>
                            <Button Grid.Column="3" Content="Space" Tag="SPACE" Click="Key_Click" FontSize="18"/>
                            <Button Grid.Column="4" Content="←" Tag="LEFT" Click="Key_Click" FontSize="22"/>
                            <Button Grid.Column="5" Content="↓" Tag="DOWN" Click="Key_Click" FontSize="22"/>
                            <Button Grid.Column="6" Content="→" Tag="RIGHT" Click="Key_Click" FontSize="22"/>
                            <Button Grid.Column="7" Content="Home" Tag="HOME" Click="Key_Click" FontSize="15"/>
                            <Button Grid.Column="8" Content="End" Tag="END" Click="Key_Click" FontSize="15"/>
                        </Grid>
                    </Grid>

                    <!-- Numpad (shown for Full) -->
                    <Grid x:Name="NumpadGrid" Grid.Column="1" Margin="4,0,0,0" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/><RowDefinition Height="*"/><RowDefinition Height="*"/>
                            <RowDefinition Height="*"/><RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Row="0" Grid.Column="0" Content="NLk" Tag="NUMLK"   Click="Key_Click" FontSize="14"/>
                        <Button Grid.Row="0" Grid.Column="1" Content="/"   Tag="NUMSLASH" Click="Key_Click" FontSize="18"/>
                        <Button Grid.Row="0" Grid.Column="2" Content="*"   Tag="NUMSTAR"  Click="Key_Click" FontSize="18"/>
                        <Button Grid.Row="0" Grid.Column="3" Content="-"   Tag="NUMMINUS" Click="Key_Click" FontSize="18"/>
                        <Button Grid.Row="1" Grid.Column="0" Content="7"   Tag="NUM7"     Click="Key_Click"/>
                        <Button Grid.Row="1" Grid.Column="1" Content="8"   Tag="NUM8"     Click="Key_Click"/>
                        <Button Grid.Row="1" Grid.Column="2" Content="9"   Tag="NUM9"     Click="Key_Click"/>
                        <Button Grid.Row="1" Grid.Column="3" Grid.RowSpan="2" Content="+" Tag="NUMPLUS" Click="Key_Click" FontSize="18"/>
                        <Button Grid.Row="2" Grid.Column="0" Content="4"   Tag="NUM4"     Click="Key_Click"/>
                        <Button Grid.Row="2" Grid.Column="1" Content="5"   Tag="NUM5"     Click="Key_Click"/>
                        <Button Grid.Row="2" Grid.Column="2" Content="6"   Tag="NUM6"     Click="Key_Click"/>
                        <Button Grid.Row="3" Grid.Column="0" Content="1"   Tag="NUM1"     Click="Key_Click"/>
                        <Button Grid.Row="3" Grid.Column="1" Content="2"   Tag="NUM2"     Click="Key_Click"/>
                        <Button Grid.Row="3" Grid.Column="2" Content="3"   Tag="NUM3"     Click="Key_Click"/>
                        <Button Grid.Row="3" Grid.Column="3" Grid.RowSpan="2" Content="↵" Tag="ENTER" Click="Key_Click" FontSize="20"/>
                        <Button Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Content="0" Tag="NUM0" Click="Key_Click"/>
                        <Button Grid.Row="4" Grid.Column="2" Content="."   Tag="NUMDOT"   Click="Key_Click" FontSize="18"/>
                    </Grid>
                </Grid>

            </Grid>
        </Border>
    </Viewbox>
</Window>
